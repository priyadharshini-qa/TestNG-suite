    <classes>
      <class name="pc.ch03.ParallelExecution.Test1_ParallelByTest"/>
      <class name="pc.ch03.ParallelExecution.Test2_ParallelByTest"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
